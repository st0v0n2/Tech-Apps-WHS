[node name="PlayAgainButton" type="Button" parent="MainLayout/ResultPanel/VBoxContainer"]
layout_mode = 2
text = "Play Again"

[node name="FairnessPanel" parent="MainLayout" instance=ExtResource("3_fairness")]
unique_name_in_owner = true
visible = false
layout_mode = 2
size_flags_horizontal = 4

[connection signal="value_changed" from="MainLayout/Settings/TargetMultiplier" to="." method="_on_target_changed"]
[connection signal="pressed" from="MainLayout/Header/BackButton" to="." method="_on_back_pressed"]
[connection signal="pressed" from="MainLayout/PlayButton" to="." method="_on_play_pressed"]
[connection signal="pressed" from="MainLayout/ResultPanel/VBoxContainer/ShowFairnessButton" to="." method="_on_show_fairness_pressed"]
